# ─────────────────────────────────────────────────────────────────
# Closer Control Lead Intel — self-host deploy.
# Copy to .env on the server and fill every value. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Public URLs ──
# For VPS:   leadintel.sepnexus.com / leadintel-api.sepnexus.com
# For local: http://localhost:3001  / http://localhost:54322
PUBLIC_HOST=leadintel.sepnexus.com
PUBLIC_API_HOST=leadintel-api.sepnexus.com
SITE_URL=https://leadintel.sepnexus.com
VITE_SUPABASE_URL=https://leadintel-api.sepnexus.com
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME_same_value_as_ANON_KEY
VITE_SUPABASE_PROJECT_ID=leadintel-selfhost

# ── Cross-app navigation (AppSwitcher + back-to-launcher) ──
VITE_OTHER_APP_URL=https://acq.sepnexus.com
VITE_OTHER_APP_NAME=ACQ Coach
VITE_LAUNCHER_URL=https://platform.sepnexus.com

# ── Database (use `make keys`) ──
POSTGRES_DB=leadintel
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_password
AUTHENTICATOR_PASSWORD=CHANGE_ME_postgrest_role_password
AUTH_ADMIN_PASSWORD=CHANGE_ME_gotrue_admin_password

# ── JWT (use `make keys`) ──
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_40_chars
ANON_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_anon
SERVICE_ROLE_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_service_role

# ── Auth (GoTrue) ──
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_URI_ALLOW_LIST=
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://leadintel-api.sepnexus.com/auth/v1/callback

# ── Edge function secrets ──
# Used by ai-analyze, analyze-lead, generate-day-briefing
ANTHROPIC_API_KEY=

# Used by tts-briefing
DEEPGRAM_API_KEY=

# Stripe — both modes. _shared/stripe.ts must be rewritten to drop the
# Lovable connector gateway before any Stripe call works on self-host.
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# Cron auth (must match the value in vault.cron_secret + cron job header)
CRON_SECRET=

# Legacy single-tenant GHL fallback (per-tenant values live in tenants.ghl_pit_token)
GHL_PIT_TOKEN=
GHL_LOCATION_ID=

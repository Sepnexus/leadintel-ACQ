# Sepnexus Platform — VPS environment template.
# Copy to .env.vps and fill in.
#
#   cp .env.vps.example .env.vps
#   bash scripts/gen-vps-secrets.sh   # generates the secret block, paste it in
#   nano .env.vps                     # fill the remaining values
#
# This file is loaded by `docker compose --env-file .env.vps -f docker-compose.vps.yml`.
# Each project's local .env (acq-coach-selfhost/.env, etc.) does NOT need to
# be filled when deploying via the top-level compose — values flow from here.

# ─── PUBLIC URLS ────────────────────────────────────────────────────────────
# All on Hostinger's built-in *.srv844822.hstgr.cloud wildcard — no DNS to
# manage, no nameserver changes, Traefik already routes the wildcard cert.
# Same pattern iBuyKC dashboards use (dashboard.srv844822.hstgr.cloud).
LAUNCHER_HOST=closercontrol.srv844822.hstgr.cloud
ACQ_HOST=acq.srv844822.hstgr.cloud
ACQ_API_HOST=api-acq.srv844822.hstgr.cloud
LEADINTEL_HOST=leadintel.srv844822.hstgr.cloud
LEADINTEL_API_HOST=api-leadintel.srv844822.hstgr.cloud

# Frontend URLs (the launcher's nginx writes these into config.json on boot)
ACQ_URL=https://acq.srv844822.hstgr.cloud
ACQ_API_URL=https://api-acq.srv844822.hstgr.cloud
LEADINTEL_URL=https://leadintel.srv844822.hstgr.cloud
LEADINTEL_API_URL=https://api-leadintel.srv844822.hstgr.cloud
# Same-origin proxy: browser hits closercontrol.../auth/*, launcher nginx
# forwards to platform-auth internally. No separate auth subdomain.
PLATFORM_AUTH_URL=https://closercontrol.srv844822.hstgr.cloud/auth

# ─── SECRETS (run `bash scripts/gen-vps-secrets.sh` to fill these) ──────────
JWT_SECRET=PASTE_FROM_GEN_SECRETS
TOKEN_ENCRYPTION_KEY=PASTE_FROM_GEN_SECRETS
PLATFORM_POSTGRES_PASSWORD=PASTE_FROM_GEN_SECRETS

ACQ_POSTGRES_PASSWORD=PASTE_FROM_GEN_SECRETS
ACQ_AUTHENTICATOR_PASSWORD=PASTE_FROM_GEN_SECRETS
ACQ_AUTH_ADMIN_PASSWORD=PASTE_FROM_GEN_SECRETS
ACQ_ANON_KEY=PASTE_FROM_GEN_SECRETS
ACQ_SERVICE_ROLE_KEY=PASTE_FROM_GEN_SECRETS

LEADINTEL_POSTGRES_PASSWORD=PASTE_FROM_GEN_SECRETS
LEADINTEL_AUTHENTICATOR_PASSWORD=PASTE_FROM_GEN_SECRETS
LEADINTEL_AUTH_ADMIN_PASSWORD=PASTE_FROM_GEN_SECRETS
LEADINTEL_ANON_KEY=PASTE_FROM_GEN_SECRETS
LEADINTEL_SERVICE_ROLE_KEY=PASTE_FROM_GEN_SECRETS

# ─── EXTERNAL SERVICES ──────────────────────────────────────────────────────
# Stripe — for billing/wallet top-up. Get from dashboard.stripe.com.
# Secret keys are platform-wide (one Stripe account, both apps).
# Webhook signing secrets are PER-ENDPOINT: register one webhook per app per
# mode in the Stripe dashboard, each gives its own whsec_.
#   ACQ webhook URL:  https://api-acq.srv844822.hstgr.cloud/functions/v1/payments-webhook?env=test  (or live)
#   LI  webhook URL:  https://api-leadintel.srv844822.hstgr.cloud/functions/v1/payments-webhook?env=test  (or live)
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=
ACQ_STRIPE_TEST_WEBHOOK_SECRET=
ACQ_STRIPE_LIVE_WEBHOOK_SECRET=
LEADINTEL_STRIPE_TEST_WEBHOOK_SECRET=
LEADINTEL_STRIPE_LIVE_WEBHOOK_SECRET=

# AI providers — at least one is needed for ACQ scoring + LI lead intelligence.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Default password for any seed users created on first boot (overridable per-user later)
DEFAULT_USER_PASSWORD=ChangeMeOnFirstLogin@2026

# ─── GoTrue tuning ──────────────────────────────────────────────────────────
GOTRUE_DISABLE_SIGNUP=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_URI_ALLOW_LIST=https://closercontrol.srv844822.hstgr.cloud,https://acq.srv844822.hstgr.cloud,https://leadintel.srv844822.hstgr.cloud

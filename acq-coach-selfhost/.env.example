# ─────────────────────────────────────────────────────────────────
# ACQ Coach — self-host deploy.
# Copy to .env on the server and fill every value. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Public URLs (must match Traefik labels in docker-compose.yml) ──
PUBLIC_HOST=acq.sepnexus.com
PUBLIC_API_HOST=acq-api.sepnexus.com
SITE_URL=https://acq.sepnexus.com
VITE_SUPABASE_URL=https://acq-api.sepnexus.com
# Same value as ANON_KEY below — the frontend reads this name (Lovable convention).
# Both are baked into the JS bundle at build time, so you MUST set this before
# `docker compose up --build`. If left empty, every Supabase call from the
# browser silently fails with a "NETWORK_ERROR" toast.
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME_same_value_as_ANON_KEY
VITE_SUPABASE_PROJECT_ID=acqcoach-selfhost
# Drop this if you've ripped out the Lovable Payments client checkout widget
# from the frontend (recommended). Keep if you're still in transition.
VITE_PAYMENTS_CLIENT_TOKEN=

# ── Database passwords (pick long random strings — use `make keys`) ──
POSTGRES_DB=acqcoach
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_password
AUTHENTICATOR_PASSWORD=CHANGE_ME_postgrest_role_password
AUTH_ADMIN_PASSWORD=CHANGE_ME_gotrue_admin_password

# ── JWT secret + derived public keys (use `make keys`) ──
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_40_chars
ANON_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_anon
SERVICE_ROLE_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_service_role

# ── Auth (GoTrue) overrides ──
# Set to true to disable open registration (admin-invites only).
GOTRUE_DISABLE_SIGNUP=false
# Set to false to require email verification before login.
GOTRUE_MAILER_AUTOCONFIRM=true
# Comma-separated allow-list for OAuth/email-magic-link redirects.
# Default = SITE_URL + SITE_URL/*. Add localhost for dev if needed.
GOTRUE_URI_ALLOW_LIST=

# Google OAuth (if you confirmed in the Supabase dashboard that Google was on).
# Get a fresh client ID + secret from console.cloud.google.com — the old
# Lovable redirect URI won't work for the new domain.
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://acq-api.sepnexus.com/auth/v1/callback

# ── Edge function secrets ──
# Used by ai-chat (gpt-5.4-mini scoring/chat) and ai-tts (tts-1)
OPENAI_API_KEY=

# Used by transcribe (Nova-3 with diarization)
DEEPGRAM_API_KEY=

# Fallback scoring path (primary path is OpenAI; this is rarely hit)
ANTHROPIC_API_KEY=

# Stripe — both modes; flip stripe_mode in app_settings to pick which is active.
# IMPORTANT: _shared/stripe.ts must be rewritten to drop the Lovable connector
# gateway before any Stripe call will work on self-host. See task #7.
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# Used by cron-sync + auto-recharge-cron to authenticate pg_cron's HTTP calls.
# Must match the x-cron-secret header in backups/migration-export/cron-jobs.sql.
CRON_SECRET=

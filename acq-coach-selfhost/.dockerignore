.git
.gitignore
.dockerignore
.env
.env.local
.env.*.local
.DS_Store

# node deps (rebuilt inside the image)
**/node_modules
**/dist
**/.next

# editor / OS
.vscode
.idea
*.log

# our local stuff
backups/
docs/
README.md
Makefile
scripts/

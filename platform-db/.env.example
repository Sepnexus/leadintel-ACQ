# ── Platform DB env ──
# Three passwords: superuser (admin/migrations), platform_app (app runtime),
# platform_admin (launcher Admin Console).

POSTGRES_PASSWORD=CHANGE_ME_platform_db_superuser_password
PLATFORM_APP_PASSWORD=CHANGE_ME_platform_app_runtime_password
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_platform_admin_password

# Host port for `psql` from the laptop. Change if 54432 is taken.
HOST_PORT=54432
